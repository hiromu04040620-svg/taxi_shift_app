default_platform(:ios)

require "fileutils"

APP_IDENTIFIER = "com.sasame.takushiftokun"
IPA_PATH = File.expand_path("../build/ios/ipa/TaxiShift.ipa", __dir__)

def flutter_version
  pubspec = File.read(File.expand_path("../pubspec.yaml", __dir__))
  match = pubspec.match(/^version:\s*([0-9]+\.[0-9]+\.[0-9]+)\+([0-9]+)/)
  UI.user_error!("pubspec.yaml の version は 1.0.0+3 の形式にしてください") unless match

  {
    name: match[1],
    number: match[2]
  }
end

def app_store_connect_api_key_from_env
  key_id = ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"]
  issuer_id = ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"]
  key_filepath = ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
  key_content = ENV["APP_STORE_CONNECT_API_KEY_KEY"]

  return nil if key_id.to_s.empty?

  options = {
    key_id: key_id,
    issuer_id: issuer_id,
    duration: 1200,
    in_house: false
  }

  if !key_filepath.to_s.empty?
    options[:key_filepath] = key_filepath
  elsif !key_content.to_s.empty?
    options[:key_content] = key_content
    options[:is_key_content_base64] =
      ENV["APP_STORE_CONNECT_API_KEY_IS_KEY_CONTENT_BASE64"] == "true"
  else
    UI.user_error!(
      "APP_STORE_CONNECT_API_KEY_KEY_FILEPATH または " \
      "APP_STORE_CONNECT_API_KEY_KEY を設定してください"
    )
  end

  app_store_connect_api_key(**options)
end

platform :ios do
  desc "Build App Store IPA from Flutter pubspec version"
  lane :build_ipa do
    version = flutter_version
    FileUtils.rm_rf(File.dirname(IPA_PATH))
    sh(
      "flutter build ipa --release " \
      "--build-name=#{version[:name]} " \
      "--build-number=#{version[:number]}"
    )
    UI.user_error!("IPA was not generated at #{IPA_PATH}") unless File.exist?(IPA_PATH)
    UI.success("Built #{IPA_PATH}")
  end

  desc "Build and upload IPA to App Store Connect / TestFlight"
  lane :upload_testflight do |options|
    build_ipa unless options[:skip_build]

    api_key = app_store_connect_api_key_from_env
    upload_options = {
      app_identifier: APP_IDENTIFIER,
      ipa: IPA_PATH,
      skip_waiting_for_build_processing: true,
      uses_non_exempt_encryption: false
    }
    upload_options[:api_key] = api_key unless api_key.nil?

    upload_to_testflight(**upload_options)
  end

  desc "Prepare App Store screenshot files from the current simulator screenshots"
  lane :prepare_screenshots do
    sh("mkdir -p screenshots/ja-JP")
    sh("cp ../screenshots/app_store/iphone_65_01_1284x2778.png 'screenshots/ja-JP/01_iPhone_6_5.png'")
    sh("cp ../screenshots/app_store/ipad_13_01.png 'screenshots/ja-JP/01_iPad_13.png'")
    sh("sips -g pixelWidth -g pixelHeight screenshots/ja-JP/*.png")
  end

  desc "Upload screenshots only to App Store Connect"
  lane :upload_screenshots do
    prepare_screenshots
    deliver
  end
end
