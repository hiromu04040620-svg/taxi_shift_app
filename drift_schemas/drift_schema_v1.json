  "fixed_sql": [
    {
      "name": "shift_patterns",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"shift_patterns\" (\"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"updated_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"work_style\" TEXT NOT NULL, \"cycle\" TEXT NOT NULL, \"start_date\" INTEGER NOT NULL, \"valid_from\" INTEGER NOT NULL, \"valid_until\" INTEGER NULL, \"is_active\" INTEGER NOT NULL CHECK (\"is_active\" IN (0, 1)));"
        }
      ]
    },
    {
      "name": "shift_overrides",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"shift_overrides\" (\"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"updated_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"date\" TEXT NOT NULL UNIQUE, \"shift_type\" TEXT NOT NULL, \"status\" TEXT NOT NULL, \"reason\" TEXT NULL, \"paired_override_id\" INTEGER NULL REFERENCES shift_overrides (id) ON DELETE SET NULL);"
        }
      ]
    },
    {
      "name": "revenues",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"revenues\" (\"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"updated_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"date\" TEXT NOT NULL UNIQUE, \"gross_revenue\" INTEGER NOT NULL, \"tax_excluded_revenue\" INTEGER NOT NULL, \"cash_amount\" INTEGER NOT NULL, \"cashless_amount\" INTEGER NOT NULL, \"other_amount\" INTEGER NOT NULL, \"total_distance\" REAL NOT NULL, \"occupied_distance\" REAL NOT NULL, \"rides_count\" INTEGER NOT NULL, \"fuel_amount\" INTEGER NULL, \"photo_path\" TEXT NULL, \"note\" TEXT NULL);"
        }
      ]
    },
    {
      "name": "work_sessions",
      "sql": [
